# ═══════════════════════════════════════════════════════════════════════════════
# NextStop — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Fill in real values in .env
# 3. NEVER commit .env to git — only commit .env.example
# ═══════════════════════════════════════════════════════════════════════════════


# ─── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=NextStop


# ─── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=nextstop_app
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=nextstop
DB_POOL_MIN=2
DB_POOL_MAX=20


# ─── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_48_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_48_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d


# ═══════════════════════════════════════════════════════════════════════════════
#  ⚠️  INTERSWITCH — TWO SEPARATE CREDENTIAL SETS (DO NOT MIX)
# ═══════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────────
# SET A — Quickteller Business  (PAYMENTS, WEBHOOKS, SETTLEMENTS)
# ───────────────────────────────────────────────────────────────────────────────
#
# ✅ Use for: initiatePayment, verifyTransaction, webhooks, Split-Settlements
# ❌ Never use for: NIN, Driver's Licence, BVN, OTP
#
# HOW TO GET:
#   1. Log in → https://business.quickteller.com
#   2. Left sidebar (see Image 3) → click "Developer Tools"
#   3. Integrations sub-tab → copy Client ID, Client Secret, Product ID, Pay Item ID
#
# SERVICES TO SET UP in that sidebar (Image 3):
#   ✅ Developer Tools  → get your API keys and register webhook URL
#   ✅ Settlements      → add your NGN bank account for platform earnings
#   ✅ Split-Settlements→ configure driver/platform payout split percentages
#   ✅ Transactions     → monitor all payment records
# ───────────────────────────────────────────────────────────────────────────────

# From: Quickteller Business → Developer Tools → Integrations → "Client ID"
QTB_CLIENT_ID=QTB_CLIENT_ID_PLACEHOLDER

# From: Quickteller Business → Developer Tools → Integrations → "Client Secret"
QTB_CLIENT_SECRET=QTB_CLIENT_SECRET_PLACEHOLDER

# From: Quickteller Business → Developer Tools → Integrations → "Product ID"
QTB_PRODUCT_ID=QTB_PRODUCT_ID_PLACEHOLDER

# From: Quickteller Business → Developer Tools → Integrations → "Pay Item ID"
QTB_PAY_ITEM_ID=QTB_PAY_ITEM_ID_PLACEHOLDER

# HOW TO GET WEBHOOK SECRET (Image 2):
#   1. Quickteller Business → Developer Tools → Webhooks sub-tab
#   2. In the "Add a webhook endpoint" form, enter your server's public URL:
#      https://api.nextstop.ng/webhooks/interswitch
#   3. Click "Save changes"
#   4. Quickteller Business THEN REVEALS your HMAC signing secret
#   5. Copy that revealed secret here ↓
QTB_WEBHOOK_SECRET=QTB_WEBHOOK_SECRET_PLACEHOLDER

# OAuth2 token endpoint for Quickteller Business
# Sandbox:    https://sandbox.interswitchng.com
# Production: https://passport.interswitchng.com
QTB_PASSPORT_URL=https://sandbox.interswitchng.com

# Quickteller Business base API URL
# Sandbox:    https://sandbox.interswitchng.com
# Production: https://api.interswitchng.com
QTB_BASE_URL=https://sandbox.interswitchng.com

# Transaction verification endpoint
# Sandbox:    https://sandbox.interswitchng.com/collections/api/v1/gettransaction.json
# Production: https://api.interswitchng.com/collections/api/v1/gettransaction.json
QTB_VERIFY_URL=https://sandbox.interswitchng.com/collections/api/v1/gettransaction.json

# Redirect URL ISW sends users back to after Webpay payment
# Must be a URL your Flutter app intercepts (deep link or universal link)
PAYMENT_REDIRECT_URL=https://nextstop.ng/payment/callback


# ───────────────────────────────────────────────────────────────────────────────
# SET B — API Marketplace  (KYC APIS + OTP ONLY)
# ───────────────────────────────────────────────────────────────────────────────
#
# ✅ Use for: NIN, Driver's Licence, BVN, Bank Verify, WhatsApp OTP, Safetoken
# ❌ Never use for: payment initiation, transaction verification
#
# HOW TO GET:
#   1. Log in → https://developer.interswitchgroup.com
#   2. Open or create your "NextStop" project
#   3. Subscribe to each API you need (from Image 1):
#        ✅ NIN API                       (required for driver onboarding)
#        ✅ Driver's License Verification  (required for driver onboarding)
#        ✅ WhatsApp OTP API              (required for phone verification)
#        🔲 Bank Account Verification     (subscribe when building payout flow)
#        🔲 BVN Full Details API          (subscribe when building premium KYC)
#        🔲 Generate Safetoken OTP API    (subscribe when building 2FA)
#        🔲 Bank Accounts Lookup API      (subscribe when building driver payout selection)
#   4. Go to "Test API keys" section → copy Client ID and Client Secret
#
# TOKEN ENDPOINT (confirmed from Images 6 & 7):
#   POST https://qa.interswitchng.com/passport/oauth/token
#   Header: Authorization: Basic Base64(CLIENT_ID:SECRET_KEY)
#   Header: Content-Type: application/x-www-form-urlencoded
#   Body:   grant_type=client_credentials&scope=profile
# ───────────────────────────────────────────────────────────────────────────────

# From: API Marketplace → NextStop Project → Test API keys → "Client ID"
MKT_CLIENT_ID=MKT_CLIENT_ID_PLACEHOLDER

# From: API Marketplace → NextStop Project → Test API keys → "Client Secret"
MKT_CLIENT_SECRET=MKT_CLIENT_SECRET_PLACEHOLDER

# Marketplace Passport URL (confirmed from Image 6 — uses qa.interswitchng.com for sandbox)
# Sandbox:    https://qa.interswitchng.com
# Production: https://passport.k8.isw.la
MKT_PASSPORT_URL=https://qa.interswitchng.com

# ── NIN Verification API ────────────────────────────────────────────────────────
# TODO: Confirm exact URL from API Marketplace → NIN API → Endpoints tab
MKT_NIN_URL=https://api-marketplace-routing.k8.isw.la/marketplace-routing/api/v2/customers/nin

# ── Driver's Licence Verification API ──────────────────────────────────────────
# TODO: Confirm exact URL from API Marketplace → Driver's License API → Endpoints tab
MKT_DL_URL=https://api-marketplace-routing.k8.isw.la/marketplace-routing/api/v2/customers/dl

# ── WhatsApp OTP API ────────────────────────────────────────────────────────────
# Confirmed from Images 4 & 5 — exact URL visible in code snippet on Marketplace docs
MKT_WHATSAPP_OTP_URL=https://api-marketplace-routing.k8.isw.la/marketplace-routing/api/v1/whatsapp/auth/send

# ── Bank Account Verification API ───────────────────────────────────────────────
# TODO: Subscribe to this API in your NextStop project, then confirm URL from Endpoints tab
MKT_BANK_VERIFY_URL=https://api-marketplace-routing.k8.isw.la/marketplace-routing/api/v2/bank/account/verify

# ── BVN Full Details API ────────────────────────────────────────────────────────
# TODO: Subscribe to this API in your NextStop project, then confirm URL from Endpoints tab
MKT_BVN_URL=https://api-marketplace-routing.k8.isw.la/marketplace-routing/api/v2/customers/bvn

# ── Generate Safetoken OTP API ──────────────────────────────────────────────────
# TODO: Subscribe to this API in your NextStop project, then confirm URL from Endpoints tab
MKT_SAFETOKEN_URL=https://api-marketplace-routing.k8.isw.la/marketplace-routing/api/v1/safetoken/generate

# ── Bank Accounts Lookup API ────────────────────────────────────────────────────
# TODO: Subscribe to this API in your NextStop project, then confirm URL from Endpoints tab
MKT_BANK_LOOKUP_URL=https://api-marketplace-routing.k8.isw.la/marketplace-routing/api/v2/bank/accounts/lookup


# ─── Platform Config ────────────────────────────────────────────────────────────
PLATFORM_FEE_PCT=0.15
BASE_CURRENCY=NGN
FRONTEND_URL=https://nextstop.ng


# ─── Redis (Socket.io adapter + rate limiting) ──────────────────────────────────
REDIS_URL=redis://localhost:6379


# ─── Field Encryption (sensitive DB fields at rest) ─────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
FIELD_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_HERE
